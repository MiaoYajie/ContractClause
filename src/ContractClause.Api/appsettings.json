{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Database": {
    "Provider": "PostgreSQL",
    "ConnectionString": "Host=localhost;Port=5432;Database=contractclause;Username=app;Password=secret"
  },
  "VectorStore": {
    "Provider": "Qdrant",
    "Qdrant": {
      "Endpoint": "http://localhost:6333",
      "ApiKey": "",
      "VectorSize": 2048
    }
  },
  "FatianshiTemplateSync": {
    "Enabled": true,
    "BaseUrl": "https://contentadmin.fatianshi.cn",
    "IntervalHours": 24,
    "PageSize": 50,
    "RecommendOnly": true,
    "ApiKey": ""
  },
  "TemplateBlob": {
    "ConnectionString": "",
    "SourceContainerName": "template",
    "OutputContainerName": "contractclause",
    "SourceBlobPathFormat": "{templateId}/{version}",
    "OutputBlobDirectoryFormat": "template/{templateId}"
  },
  "Ai": {
    "EmbeddingModel": {
      "BaseUrl": "",
      "ApiKey": "",
      "ModelId": "text-embedding-v4",
      "Dimensions": 2048
    },
    "TextModel": {
      "BaseUrl": "",
      "ApiKey": "",
      "ModelId": ""
    }
  },
  "AuthServer": {
    "Authority": "https://auth.fatianshi.cn",
    "ApiName": "",
    "RequireHttpsMetadata": false,
    "ApiSecret": ""
  },
  "AllowedHosts": "*"
}
